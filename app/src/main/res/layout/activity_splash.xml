<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Animated gradient circle background -->
    <View
        android:id="@+id/gradientCircle"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_fab"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App Icon -->
    <ImageView
        android:id="@+id/splashIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_scan"
        android:background="@drawable/bg_fab"
        android:padding="24dp"
        android:scaleType="centerInside"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38" />

    <!-- App Name -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.1"
        android:alpha="0"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/splashIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/splashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textSize="14sp"
        android:textColor="@color/on_surface_medium"
        android:letterSpacing="0.15"
        android:alpha="0"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/splashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Developer Credit -->
    <TextView
        android:id="@+id/splashDeveloper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/developed_by"
        android:textSize="12sp"
        android:textColor="@color/on_surface_low"
        android:letterSpacing="0.1"
        android:alpha="0"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/splashTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/splashProgress"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:alpha="0"
        android:indeterminateTint="@color/primary_light"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
