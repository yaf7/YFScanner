<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.YFScanner" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.YFScanner" parent="Base.Theme.YFScanner" />

    <!-- Splash Theme -->
    <style name="Theme.YFScanner.Splash" parent="Base.Theme.YFScanner">
        <item name="android:colorBackground">@color/splash_bg</item>
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.YFScanner.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.YFScanner.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
    </style>
</resources>